@model IEnumerable<Midterm_BCS240037.Models.Dish_BCS240037>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<form asp-action="Index" method="get" class="row mb-4">
    <div class="col-md-2">
        <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Tìm tên món..." />
    </div>
    <div class="col-md-2">
        <select name="categoryId" asp-items="@ViewBag.CategoryId" class="form-control">
            <option value="">-- Chọn loại --</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="isAvailable" class="form-control">
            <option value="">-- Trạng thái --</option>
            <option value="true" selected="@(ViewBag.IsAvailable == true)">Đang bán</option>
            <option value="false" selected="@(ViewBag.IsAvailable == false)">Ngừng bán</option>
        </select>
    </div>
    <div class="col-md-2">
        <input type="number" name="minPrice" value="@ViewBag.MinPrice" class="form-control" placeholder="Giá từ..." />
    </div>
    <div class="col-md-2">
        <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" class="form-control" placeholder="Đến giá..." />
    </div>
    <div class="col-md-2">
        <select name="sortOrder" class="form-control">
            <option value="">-- Sắp xếp --</option>
            <option value="price_asc" selected="@(ViewBag.SortOrder == "price_asc")">Giá tăng dần</option>
            <option value="price_desc" selected="@(ViewBag.SortOrder == "price_desc")">Giá giảm dần</option>
            <option value="time_asc" selected="@(ViewBag.SortOrder == "time_asc")">Thời gian chế biến tăng</option>
        </select>
    </div>
    <div class="col-12 mt-2">
        <button type="submit" class="btn btn-primary">Tìm kiếm / Lọc</button>
        <a asp-action="Index" class="btn btn-secondary">Xóa bộ lọc</a>
    </div>
</form>
@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger mt-3">@ViewBag.ErrorMessage</div>
}
else if (!Model.Any())
{
    <div class="alert alert-warning mt-3">Không tìm thấy kết quả phù hợp.</div>
}
else
{
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Price)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PreparationTime)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IsAvailable)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DishCategory)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Price)
            </td>
                <td>
                    @item.PreparationTime phút
                    <span class="badge bg-info text-dark">@item.PrepTimeCategory</span>
                </td>
                <td>
                    @if (item.IsAvailable)
                    {
                        <span class="badge bg-success">Đang bán</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Ngừng bán</span>
                    }
                </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DishCategory.Name)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
}
